{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "zerogravitynky/zg-reviews",
  "version": "1.0.0",
  "title": "ZG Reviews",
  "category": "zerogravitynky",
  "icon": "star-filled",
  "description": "Displays 3 random published reviews from the Reviews post type. Background color is configurable.",
  "attributes": {
    "bgColor":      { "type": "string", "default": "lavender", "enum": ["lavender", "light-gold", "purple"] },
    "sectionTitle": { "type": "string", "default": "What Our Clients Say" },
    "ratingLabel":  { "type": "string", "default": "5.0 · Consistently 5-star rated" }
  },
  "supports": { "html": false, "align": ["full"] },
  "render":       "file:./render.php",
  "editorScript": "zg-blocks"
}
